# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# Прокси для Telegram (раскомментируй если Telegram недоступен напрямую)
# TELEGRAM_PROXY_URL=socks5://127.0.0.1:1080
# TELEGRAM_PROXY_URL=http://127.0.0.1:8080

# Z.AI (https://api.z.ai/api/paas/v4/)
ZAI_API_KEY=your_zai_api_key_here

# ProxyAPI (https://api.proxyapi.ru/openai/v1)
PROXY_API_KEY=your_proxyapi_key_here

# GenAPI (https://proxy.gen-api.ru/v1)
GEN_API_KEY=your_genapi_key_here

# MCP Server
MCP_SERVER_URL=http://localhost:8000
